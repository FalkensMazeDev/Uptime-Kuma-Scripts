# ── Credentials & configuration ──────────────────────────────
.env
*.env
.env.*

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
.env/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# ── IDE & editor files ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs & temp files ─────────────────────────────────────────
*.log
*.tmp
*.bak
